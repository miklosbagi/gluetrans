# Gluetun OpenVPN credentials (PIA: use PIA OpenVPN username + password).
TEST_VPN_USER=${GLUETRANS_VPN_USERNAME}
TEST_VPN_PASS=${GLUETRANS_VPN_PASSWORD}
# PIA: comma-separated SERVER_REGIONS values (Gluetun PIA region names), e.g.
# "Switzerland,DE Berlin,FI Helsinki" — must support port forwarding; set via GLUETRANS_VPN_REGIONS in CI.
TEST_VPN_REGIONS=${GLUETRANS_VPN_REGIONS}
TEST_T_USER=${GLUETRANS_TRANSMISSION_USERNAME}
TEST_T_PASS=${GLUETRANS_TRANSMISSION_PASSWORD}
